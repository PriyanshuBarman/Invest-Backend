generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(uuid())
  name             String
  email            String             @unique
  password         String?
  isAdmin          Boolean            @default(false)
  avatar           String?
  balance          Decimal            @default(1000.00) @db.Decimal(10, 2)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @default(now()) @updatedAt
  transactions     Transaction[]
  mfPortfolio      MfPortfolio[]
  mfHolding        MfHolding[]
  stockPortfolio   StockPortfolio[]
  stockHoldings    StockHolding[]
  portfolioSummary PortfolioSummary[]
}

// ======== Transaction =======

model Transaction {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Decimal         @db.Decimal(10, 2)
  assetType AssetType? //
  code      String?
  name      String?
  tnxType   TransactionType
  quantity  Decimal?        @db.Decimal(10, 2) //
  puchaseAt Decimal?        @db.Decimal(10, 4) //
  createdAt DateTime        @default(now()) //
}

enum AssetType {
  MF
  STOCK
  GOLD
}

enum TransactionType {
  DEPOSIT
  REDEEM
  INVEST
}

// ======== MfPortfolio =======

model MfPortfolio {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  latestNav      Decimal  @db.Decimal(10, 4)
  fundCode       String
  fundName       String
  fundType       FundType
  availableUnits Decimal  @db.Decimal(10, 2)
  investedAmt    Decimal  @db.Decimal(10, 2)
  marketValue    Decimal  @db.Decimal(10, 2)
  pnl            Decimal  @default(0.00) @db.Decimal(10, 2)
  roi            Decimal  @default(0.00) @db.Decimal(8, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
}

enum FundType {
  Equity
  Debt
  Hybrid
  Other
}

// ======== MfHoldings =======

model MfHolding {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fundCode     String
  fundName     String
  purchaseDate DateTime @default(now())
  purchaseNav  Decimal  @db.Decimal(10, 4)
  units        Decimal  @db.Decimal(10, 2)
  amount       Decimal  @db.Decimal(10, 2)
  updatedAt    DateTime @default(now()) @updatedAt
}

// ======== StockPortfolio =======

model StockPortfolio {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol       String
  stockName    String
  availableQty Int
  latestPrice  Decimal? @db.Decimal(10, 2)
  investedAmt  Decimal  @db.Decimal(10, 2)
  marketValue  Decimal  @db.Decimal(10, 2)
  pnl          Decimal  @default(0.00) @db.Decimal(10, 2)
  roi          Decimal  @default(0.00) @db.Decimal(8, 2)
  updatedAt    DateTime @default(now()) @updatedAt
}

// ======== StockHolding =======

model StockHolding {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol        String
  stockName     String
  investmentAmt Decimal  @db.Decimal(10, 2)
  quantity      Int      @default(0)
  purchaseDate  DateTime @default(now())
  purchasePrice Decimal  @db.Decimal(10, 2)
  updatedAt     DateTime @default(now()) @updatedAt
}

// ======== PortfolioSummary =======

model PortfolioSummary {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioType   PortfolioType
  totalInvestment Decimal       @db.Decimal(10, 2)
  totalMv         Decimal       @db.Decimal(10, 2)
  totalPnl        Decimal       @default(0.00) @db.Decimal(10, 2)
  totalRoi        Decimal       @default(0.00) @db.Decimal(8, 2)
  updatedAt       DateTime      @default(now()) @updatedAt
}

enum PortfolioType {
  MF
  STOCK
  GOLD
}
